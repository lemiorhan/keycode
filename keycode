#!/usr/bin/env bash

set -euo pipefail

# ── Resolve script directory (follows symlinks) ──

SOURCE_PATH="${BASH_SOURCE[0]}"

while [ -L "$SOURCE_PATH" ]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"

  if [[ "$SOURCE_PATH" != /* ]]; then
    SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"

# ── Load .env ──

if [ -f "$SCRIPT_DIR/.env" ]; then
  set -a
  source "$SCRIPT_DIR/.env"
  set +a
fi

# ── Usage ──

usage() {
  echo "Usage:" >&2
  echo "  keycode present <deck-name>         present all .sld files in decks/<deck-name>/" >&2
  echo "  keycode present <path/to/deck>      present all .sld files in a deck directory" >&2
  echo "  keycode preview <deck-name>         preview slides in a floating window" >&2
  echo "  keycode exportToPdf <deck-name>     export deck to PDF" >&2
  echo "  keycode exportToPdf <deck> --zoom=N export with zoom factor (default 1.0)" >&2
  echo "  keycode init <deck-name>            scaffold a new deck in decks/" >&2
  exit 1
}

if [ "$#" -lt 1 ]; then
  usage
fi

# ── Subcommand: init ──

if [ "$1" = "init" ]; then
  if [ "$#" -ne 2 ] || [ -z "$2" ]; then
    echo "Usage: keycode init <deck-name>" >&2
    exit 1
  fi

  DECK_NAME="$2"
  DECK_DIR="$SCRIPT_DIR/decks/$DECK_NAME"

  if [ -e "$DECK_DIR" ]; then
    echo "Deck already exists: decks/$DECK_NAME" >&2
    exit 1
  fi

  mkdir -p "$DECK_DIR/images"

  cat > "$DECK_DIR/01-slides.sld" <<EOF
<beautify/>
<title>
$DECK_NAME
</title>

<color fg="gray">Your Name</color>

---

<header color=cyan>
Agenda
</header>

* Introduction
* Main idea
* Demo
* Closing

---

<header color=yellow>
Key Point
</header>

<p max-width=72 align=left>
Write your content here. You can use <color fg="cyan">inline colors</color>, <footnote>footnotes</footnote>, <qr>QR codes</qr>, and split-screen media layouts.
</p>

---

<header color=magenta>
Thank You
</header>

Questions?
EOF

  echo "Created deck: decks/$DECK_NAME"
  echo "  slides: decks/$DECK_NAME/01-slides.sld"
  echo "  images: decks/$DECK_NAME/images/"
  echo ""
  echo "Run with: keycode present $DECK_NAME"
  exit 0
fi

# ── Subcommand: present ──

if [ "$1" = "present" ]; then
  if [ "$#" -ne 2 ]; then
    echo "Usage: keycode present <deck-name | path/to/deck>" >&2
    exit 1
  fi
  ARG="$2"
  CLI_ENTRY="cli"
elif [ "$1" = "preview" ]; then
  if [ "$#" -ne 2 ]; then
    echo "Usage: keycode preview <deck-name | path/to/deck>" >&2
    exit 1
  fi
  ARG="$2"
  CLI_ENTRY="previewCli"
elif [ "$1" = "exportToPdf" ]; then
  if [ "$#" -lt 2 ]; then
    echo "Usage: keycode exportToPdf <deck-name | path/to/deck> [--zoom=N]" >&2
    exit 1
  fi
  ARG="$2"
  shift 2
  EXTRA_ARGS="$*"
  CLI_ENTRY="exportPdfCli"
else
  usage
fi

# If arg contains no '/', treat as a deck name under DECK_SOURCE_PATH (or decks/)
if [[ "$ARG" != */* ]]; then
  DECK_BASE="${DECK_SOURCE_PATH:-$SCRIPT_DIR/decks}"
  DECK_DIR="$DECK_BASE/$ARG"
else
  DECK_DIR="$ARG"
fi

if [ ! -d "$DECK_DIR" ]; then
  echo "Deck directory not found: $DECK_DIR" >&2
  exit 1
fi

if [ -f "$SCRIPT_DIR/dist/src/${CLI_ENTRY}.js" ]; then
  exec node "$SCRIPT_DIR/dist/src/${CLI_ENTRY}.js" "$DECK_DIR" ${EXTRA_ARGS:-}
fi

if [ -f "$SCRIPT_DIR/src/${CLI_ENTRY}.tsx" ]; then
  exec npx tsx "$SCRIPT_DIR/src/${CLI_ENTRY}.tsx" "$DECK_DIR" ${EXTRA_ARGS:-}
fi

exec npx tsx "$SCRIPT_DIR/src/${CLI_ENTRY}.ts" "$DECK_DIR" ${EXTRA_ARGS:-}
