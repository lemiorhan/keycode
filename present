#!/usr/bin/env bash

set -euo pipefail

if [ "$#" -ne 1 ]; then
  echo "Usage: ./present <slides-folder>" >&2
  exit 1
fi

SOURCE_PATH="${BASH_SOURCE[0]}"

while [ -L "$SOURCE_PATH" ]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"

  if [[ "$SOURCE_PATH" != /* ]]; then
    SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
SLIDES_DIR="$1"

if [ ! -d "$SLIDES_DIR" ]; then
  echo "Folder not found: $SLIDES_DIR" >&2
  exit 1
fi

SLIDES_FILE="$SLIDES_DIR/slides.md"

if [ ! -f "$SLIDES_FILE" ]; then
  echo "slides.md not found in: $SLIDES_DIR" >&2
  exit 1
fi

if [ -f "$SCRIPT_DIR/dist/src/cli.js" ]; then
  exec node "$SCRIPT_DIR/dist/src/cli.js" "$SLIDES_FILE"
fi

exec npx tsx "$SCRIPT_DIR/src/cli.tsx" "$SLIDES_FILE"
