#!/usr/bin/env bash

set -euo pipefail

if [ "$#" -ne 1 ]; then
  echo "Usage: init-deck <deck-name>" >&2
  exit 1
fi

DECK_NAME="$1"

if [ -z "$DECK_NAME" ]; then
  echo "Deck name cannot be empty." >&2
  exit 1
fi

if [ -e "$DECK_NAME" ]; then
  echo "Path already exists: $DECK_NAME" >&2
  exit 1
fi

mkdir -p "$DECK_NAME/images"

cat > "$DECK_NAME/slides.md" <<EOF
<beautify/>
<title>
$DECK_NAME
</title>

<color fg="gray">Your Name</color>

---

<header color=cyan>
Agenda
</header>

* Introduction
* Main idea
* Demo
* Closing

---

<header color=yellow>
Key Point
</header>

<p max-width=72 align=left>
Write your content here. You can use <color fg="cyan">inline colors</color>, <footnote>footnotes</footnote>, <qr>QR codes</qr>, and split-screen media layouts.
</p>

---

<header color=magenta>
Thank You
</header>

Questions?
EOF

echo "Created deck: $DECK_NAME"
echo "  slides: $DECK_NAME/slides.md"
echo "  images: $DECK_NAME/images/"
